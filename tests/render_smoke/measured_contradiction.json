{
  "$schema": "https://manim-cli/schema/v1/scene.json",
  "version": "1.1",
  "name": "measured_contradiction",
  "layout_template": "plot_with_bottom_formula",
  "config": {
    "resolution": [854, 480],
    "frame_height": 8,
    "background_color": "#1e1e1e",
    "fps": 15,
    "visual_theme": "casual_3b1b"
  },
  "mobjects": [
    {
      "id": "formula",
      "type": "Tex",
      "args": {"tex": "f'(a)=\\lim_{h\\to0}\\frac{f(a+h)-f(a)}{h}", "font_size": 48},
      "layout_role": "formula.primary",
      "position": {"mode": "absolute", "point": [0, -0.5, 0]}
    },
    {
      "id": "caption",
      "type": "Text",
      "args": {"text": "Tangent slope", "font_size": 32},
      "layout_role": "caption.conclusion",
      "position": {"mode": "absolute", "point": [0, -2.35, 0]}
    }
  ],
  "steps": [
    {
      "id": "show",
      "name": "Show measured contradiction",
      "actions": [
        {"type": "write", "target": "formula", "run_time": 0.2},
        {"type": "write", "target": "caption", "run_time": 0.2}
      ],
      "wait_after": 0.1
    }
  ]
}

{
  "$schema": "https://manim-cli/schema/v1/scene.json",
  "version": "1.0",
  "name": "math_denominator_scene",
  "config": {
    "resolution": [1920, 1080],
    "frame_height": 8,
    "background_color": "#1e1e1e",
    "fps": 30,
    "visual_theme": "casual_3b1b"
  },
  "mobjects": [
    {"id": "eq", "type": "Tex", "args": {"tex": "\\frac{1}{x-1}", "font_size": 48}},
    {"id": "assign", "type": "Text", "args": {"text": "x=1", "font_size": 36}}
  ],
  "steps": [
    {"id": "s1", "name": "show equation", "actions": [{"type": "write", "target": "eq"}, {"type": "write", "target": "assign"}]}
  ]
}
